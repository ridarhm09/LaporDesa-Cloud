# LaporDesa Cloud - Environment Example
# Copy file ini ke .env dan sesuaikan dengan konfigurasi Anda

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=lapordesa_db

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET=your_super_secret_key_here_change_in_production

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,image/gif

# ============================================
# PRODUCTION NOTES
# ============================================
# 1. Ganti JWT_SECRET dengan value yang secure & random
# 2. Pastikan DB credentials benar
# 3. Ubah NODE_ENV menjadi 'production' untuk production
# 4. Setup HTTPS/SSL untuk production
# 5. Gunakan environment variables yang aman (AWS Secrets Manager, etc)
